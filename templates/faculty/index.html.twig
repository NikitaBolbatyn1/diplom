{% extends 'base.html.twig' %}

{% block title %}Факультеты{% endblock %}

{% block body %}
    <div class="table-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Факультеты и кафедры</h2>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('faculty_new') }}" class="btn btn-success">+ Добавить факультет</a>
            {% endif %}
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                <tr>
                    <th>Название факультета</th>
                    <th>Заведующий кафедры</th>
                    <th>Учёная степень</th>
                    <th>Должность</th>
                    <th>Телефон</th>
                    <th>Email</th>
                    <th>Мероприятий</th>
                    {% if is_granted('ROLE_ADMIN') %}
                        <th>Действия</th>
                    {% endif %}
                </tr>
                </thead>
                <tbody>
                {% for faculty in faculties %}
                    <tr>
                        <td>{{ faculty.name }}</td>
                        <td>{{ faculty.headName }}</td>
                        <td>{{ faculty.headDegree ?? '—' }}</td>
                        <td>{{ faculty.headPosition ?? '—' }}</td>
                        <td>{{ faculty.phone ?? '—' }}</td>
                        <td>{{ faculty.email ?? '—' }}</td>
                        <td>
                        <span class="badge {{ faculty.events|length > 0 ? 'bg-success' : 'bg-secondary' }}">
                            {{ faculty.events|length }}
                        </span>
                        </td>
                        {% if is_granted('ROLE_ADMIN') %}
                            <td>
                                <a href="{{ path('faculty_edit', {'id': faculty.id}) }}" class="btn btn-sm btn-outline-primary">✎</a>
                                <form method="post" action="{{ path('faculty_delete', {'id': faculty.id}) }}" style="display:inline-block;" onsubmit="return confirm('Удалить факультет? Все связанные мероприятия останутся без привязки.');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ faculty.id) }}">
                                    <button class="btn btn-sm btn-outline-danger">🗑</button>
                                </form>
                            </td>
                        {% endif %}
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center">Нет добавленных факультетов</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

{# templates/admin/users.html.twig #}
{% extends 'base.html.twig' %}

{% block body %}
    <div class="table-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Пользователи</h2>
            <a href="{{ path('admin_user_new') }}" class="btn btn-success">+ Новый пользователь</a>
        </div>
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Email</th>
                    <th>ФИО</th>
                    <th>Отдел</th>
                    <th>Роли</th>
                    <th>Активен</th>
                    <th>Действия</th>
                </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.id }}</td>
                        <td>{{ user.email }}</td>
                        <td>{{ user.fullName }}</td>
                        <td>{{ user.department }}</td>
                        <td>{{ user.roles|join(', ') }}</td>
                        <td>
                        <span class="badge {{ user.isActive ? 'bg-success' : 'bg-secondary' }}">
                            {{ user.isActive ? 'Да' : 'Нет' }}
                        </span>
                        </td>
                        <td>
                            <a href="{{ path('admin_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary">✎</a>
                            <form method="post" action="{{ path('admin_user_toggle', {'id': user.id}) }}" style="display:inline-block;">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                <button class="btn btn-sm btn-outline-warning" title="Активировать/деактивировать">🔁</button>
                            </form>
                            {# Кнопка удаления #}
                            <form method="post" action="{{ path('admin_user_delete', {'id': user.id}) }}" style="display:inline-block;" onsubmit="return confirm('Вы уверены, что хотите удалить этого пользователя?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Удалить">🗑</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
